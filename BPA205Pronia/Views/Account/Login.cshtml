@model LoginVM

<!-- Begin Main Content Area -->
<main class="main-content">
    <div class="breadcrumb-area breadcrumb-height"
         data-bg-image=@Url.Content("~/assets/images/breadcrumb/bg/1-1-1919x388.jpg")>
        <div class="container h-100">
            <div class="row h-100">
                <div class="col-lg-12">
                    <div class="breadcrumb-item">
                        <h2 class="breadcrumb-heading">Login Page</h2>
                        <ul>
                            <li>
                                <a asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li>Login</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="login-Login-area section-space-y-axis-100">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-6 pt-5 pt-lg-0">
                    <form asp-controller="Account" asp-action="Login" method="post" asp-route-returnUrl="@ViewBag.returnUrl">
                        <div class="text-danger" asp-validation-summary="All"></div>
                        <div class="login-form">
                            <h4 class="login-title">Login</h4>
                            <div class="row">
                                <div class="col-md-12">
                                    <label>Email Address*</label>
                                    <input asp-for="@Model.Email" type="email" placeholder="Email Address" />
                                    <span class="text-danger" asp-validation-for="@Model.Email"></span>
                                </div>
                                <div class="col-md-6">
                                    <label>Password</label>
                                    <input asp-for="@Model.Password" type="password" placeholder="Password" />
                                    <span class="text-danger" asp-validation-for="@Model.Password"></span>
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-custom-size lg-size btn-pronia-primary">
                                        Login
                                    </button>
                                </div>
                                <div class="col-12 d-flex">
                                    <p>Don't you have an account?</p>
                                    <a asp-controller="Account" asp-action="Register">Register</a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>
<!-- Main Content Area End Here -->